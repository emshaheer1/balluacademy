PORT=3001
MONGODB_URI=mongodb://localhost:27017/ballu
JWT_SECRET=your-super-secret-key-change-in-production

# Optional: Google Sign-In. Download a service account key from Firebase Console
# (Project settings → Service accounts → Generate new private key), save as JSON,
# and set this to the path to that file (e.g. ./service-account.json).
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
